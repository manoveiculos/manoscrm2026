{
    "manifest_version": 3,
    "name": "Manos CRM - WhatsApp Integration",
    "version": "1.0",
    "description": "Integração oficial Manos CRM com WhatsApp Web",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://web.whatsapp.com/*",
        "http://localhost:3000/*",
        "https://crm-manos.vercel.app/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://web.whatsapp.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "128": "icons/icon128.png"
    }
}