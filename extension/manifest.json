{
  "manifest_version": 3,
  "name": "Manos CRM - WhatsApp Extension",
  "version": "2.2.1",
  "description": "Manos CRM v2 - 4 botões nativos no WhatsApp: Lead, Kanban, Config e Novos Leads.",
  "permissions": [
    "storage",
    "activeTab",
    "alarms"
  ],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://manoscrm.com.br/*",
    "http://manoscrm.com.br/*",
    "https://*.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": [
        "content/scraper.js",
        "content/observers.js",
        "content/ui.js",
        "content/index.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "content/*.js", "styles/sidebar.css"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
