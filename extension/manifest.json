{
    "manifest_version": 3,
    "name": "Manos CRM - WhatsApp Integration",
    "version": "2.0",
    "description": "Integração oficial Manos CRM com WhatsApp Web (Versão Modular)",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://web.whatsapp.com/*",
        "http://localhost:3000/*",
        "https://manoscrm.com.br/*",
        "http://manoscrm.com.br/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://web.whatsapp.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/icon128.png",
                "content/*.js",
                "styles/sidebar.css"
            ],
            "matches": [
                "https://web.whatsapp.com/*"
            ]
        }
    ],
    "icons": {
        "128": "icons/icon128.png"
    }
}